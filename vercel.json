{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron-watcher",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron-report-check",
      "schedule": "0 8 * * *"
    }
  ]
}
