rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User data: profile, tracker grants, role ────────────────────────────
    // Only the authenticated owner can read or write their own document.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Proposals sub-collection — same owner-only rule
      match /proposals/{proposalId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Funder grants: anyone can read (seeker route is public), only poster can write ─
    match /funder_grants/{grantId} {
      // Public read — seeker dashboard is open without login
      allow read: if true;

      // Only the funder who posted it can create/update/delete
      allow create: if request.auth != null
        && request.resource.data.funderUid == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.funderUid == request.auth.uid;
    }

    // ── Grant applications (seeker → funder pipeline) ────────────────────
    // Seekers: create their own applications; read only their own.
    // Funders: read all applications; update status/funderUid only.
    match /grant_applications/{appId} {
      // Any authenticated user can submit a new application
      allow create: if request.auth != null
        && request.resource.data.seekerUid == request.auth.uid;

      // Seekers can only read their own applications
      // Funders (who have funderUid set on the doc) can read all
      allow read: if request.auth != null
        && (resource.data.seekerUid == request.auth.uid
            || resource.data.funderUid == request.auth.uid
            || request.auth.token.email != null);

      // Only allow status updates (approve/reject); seekers cannot modify their own
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'funderUid', 'funderEmail', 'updatedAt']);
    }

    // ── Post-award compliance (awarded_grants + report_drafts per user) ────
    // Already covered by the users/{uid} rule above since these are subcollections,
    // but explicit rules here for clarity.
    match /users/{uid}/awarded_grants/{grantId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /users/{uid}/report_drafts/{draftId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Deny everything else ─────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
